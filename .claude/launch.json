{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "前端代码",
      "port": 8080,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "后端代码/server",
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "viewer",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "8099", "--strictPort"],
      "cwd": "前端代码",
      "port": 8099,
      "autoPort": false
    }
  ]
}
